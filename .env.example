# Squarespace credentials
SQSP_EMAIL=your-email@example.com
SQSP_PASSWORD=your-password

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Gmail API (OAuth2)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# WhatsApp Business Cloud API (Phase 3)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
TIM_WHATSAPP_NUMBER=

# Brave Search API (for Research Agent — free tier: 2000 queries/month)
BRAVE_SEARCH_API_KEY=

# Supervisor Agent (post-execution visual verification + auto-retry)
ENABLE_SUPERVISOR=true

# Server
PORT=3000
HOST=0.0.0.0
